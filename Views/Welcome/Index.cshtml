@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome – Sigma</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:          #ffffff;
            --divider-clr: #C8102E;
            --idle-sz:     clamp(.9rem, 2.2vw, 1.4rem);
        }

        html, body {
            width: 100%; height: 100%;
            overflow: hidden;
            background: var(--bg);
            font-family: 'Segoe UI', Georgia, serif;
        }

        /* Corner brackets — hidden when welcome image is showing */
        .corner { position: fixed; width: 64px; height: 64px; z-index: 30; transition: opacity 0.4s ease; }
        .corner.tl { top:20px;    left:20px;  border-top:3px solid var(--divider-clr); border-left:3px solid var(--divider-clr); }
        .corner.tr { top:20px;    right:20px; border-top:3px solid var(--divider-clr); border-right:3px solid var(--divider-clr); }
        .corner.bl { bottom:20px; left:20px;  border-bottom:3px solid var(--divider-clr); border-left:3px solid var(--divider-clr); }
        .corner.br { bottom:20px; right:20px; border-bottom:3px solid var(--divider-clr); border-right:3px solid var(--divider-clr); }
        .corner.hide { opacity: 0; pointer-events: none; }

        /* ══ IDLE ══ */
        #idle-screen {
            position: fixed; inset: 0;
            background: var(--bg);
            display: flex; align-items: center; justify-content: center;
            z-index: 10;
            transition: opacity 0.8s ease;
        }
        #idle-screen.hidden { opacity: 0; pointer-events: none; }

        .idle-inner {
            display: flex; flex-direction: column;
            align-items: center; gap: 1.6rem;
        }

        .idle-logo {
            width: clamp(110px,16vw,220px);
            animation: logo-float 5s ease-in-out infinite;
            filter: drop-shadow(0 6px 18px rgba(200,16,46,0.14));
        }
        @@keyframes logo-float {
            0%,100% { transform: translateY(0); }
            50%      { transform: translateY(-14px); }
        }

        .idle-divider {
            width: clamp(160px,24vw,340px); height: 2px;
            background: linear-gradient(90deg,transparent,var(--divider-clr) 30%,var(--divider-clr) 70%,transparent);
            animation: div-shimmer 3s ease-in-out infinite;
        }
        @@keyframes div-shimmer {
            0%,100% { opacity:.5; transform:scaleX(.75); }
            50%      { opacity:1;  transform:scaleX(1); }
        }

        .idle-tagline {
            font-size: var(--idle-sz);
            letter-spacing: .5em; text-transform: uppercase;
            color: #1a1a1a; font-family: 'Segoe UI',sans-serif; font-weight: 300;
        }
        .idle-sub {
            font-size: clamp(.65rem,1.3vw,.88rem);
            letter-spacing: .38em; text-transform: uppercase;
            color: var(--divider-clr); font-family: 'Segoe UI',sans-serif;
        }
        .idle-dots { display:flex; gap:.5rem; }
        .idle-dot  { width:6px; height:6px; border-radius:50%; background:var(--divider-clr); opacity:.25; }
        .idle-dot:nth-child(1) { animation: dot-on 2.4s 0.0s ease-in-out infinite; }
        .idle-dot:nth-child(2) { animation: dot-on 2.4s 0.4s ease-in-out infinite; }
        .idle-dot:nth-child(3) { animation: dot-on 2.4s 0.8s ease-in-out infinite; }
        @@keyframes dot-on {
            0%,100% { opacity:.2; transform:scale(1); }
            50%      { opacity:1;  transform:scale(1.4); }
        }

        /* ══ WELCOME IMAGE ══ */
        #welcome-screen {
            position: fixed; inset: 0;
            z-index: 20;
            opacity: 0; pointer-events: none;
            transition: opacity 0.8s ease;
        }
        #welcome-screen.visible { opacity: 1; pointer-events: auto; }

        #welcome-img {
            width: 100%; height: 100%;
            object-fit: cover;
            display: block;
        }
    </style>
</head>
<body>

    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>

    <!-- IDLE -->
    <div id="idle-screen">
        <div class="idle-inner">
            <img src="/images/logo.jpg" alt="Logo" class="idle-logo" />
            <div class="idle-divider"></div>
            <div class="idle-tagline" id="idle-tagline">Hệ thống chào mừng</div>
            <div class="idle-sub"     id="idle-sub">VIP Welcome System</div>
            <div class="idle-dots">
                <div class="idle-dot"></div>
                <div class="idle-dot"></div>
                <div class="idle-dot"></div>
            </div>
        </div>
    </div>

    <!-- WELCOME IMAGE (full screen) -->
    <div id="welcome-screen">
        <img id="welcome-img" src="" alt="Welcome" />
    </div>

    <script>
    const root = document.documentElement.style;
    let POLL_MS    = 5000;
    let currentImg = null;

    function applyConfig(c) {
        if (!c) return;
        if (c.backgroundColor)    root.setProperty('--bg',          c.backgroundColor);
        if (c.dividerColor)        root.setProperty('--divider-clr', c.dividerColor);
        if (c.idleTitleSizePx)     root.setProperty('--idle-sz',     c.idleTitleSizePx + 'px');
        if (c.idleTitle)           setText('idle-tagline', c.idleTitle);
        if (c.idleSubtitle)        setText('idle-sub',     c.idleSubtitle);
        if (c.pollIntervalSeconds) POLL_MS = c.pollIntervalSeconds * 1000;
    }

    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }

    const idleEl    = document.getElementById('idle-screen');
    const welcomeEl = document.getElementById('welcome-screen');
    const imgEl     = document.getElementById('welcome-img');

    const corners = document.querySelectorAll('.corner');

    function showWelcome(imagePath) {
        if (currentImg === imagePath) return;
        currentImg = imagePath;
        imgEl.src  = imagePath;
        idleEl.classList.add('hidden');
        welcomeEl.classList.add('visible');
        corners.forEach(c => c.classList.add('hide'));
    }

    function showIdle() {
        if (currentImg === null) return;
        currentImg = null;
        welcomeEl.classList.remove('visible');
        idleEl.classList.remove('hidden');
        corners.forEach(c => c.classList.remove('hide'));
    }

    async function poll() {
        try {
            const res  = await fetch('/Welcome/GetCurrentDisplay');
            const data = await res.json();
            if (data.imagePath) showWelcome(data.imagePath);
            else                showIdle();
        } catch (e) { console.warn(e); }
    }

    async function init() {
        try {
            const res = await fetch('/Admin/Config');
            applyConfig(await res.json());
        } catch (_) {}
        poll();
        setInterval(poll, POLL_MS);
    }

    init();
    </script>
</body>
</html>
