                        </div>

                        <div class="pv-orn">
                            <div class="pv-orn-line"   id="pv-orn-l"></div>
                            <div class="pv-orn-dot"    id="pv-orn-dot"></div>
                            <div class="pv-orn-line r" id="pv-orn-r"></div>
                        </div>

                        <div class="pv-name" id="pv-name">
                            Nguyễn Văn <span class="accent" id="pv-name-accent">Sếp</span>
                        </div>
                        <div class="pv-area">Giám đốc điều hành · CEO</div>
