</div><!-- /layout -->

<div class="toast" id="toast"></div>

<script>
/* ══════════════════════════════════════════
   State
══════════════════════════════════════════ */
let cfg = {};
let currentTab = 'idle';

/* ══════════════════════════════════════════
   Accordion
══════════════════════════════════════════ */
function toggleSection(id) {
    document.getElementById(id).classList.toggle('open');
}

/* ══════════════════════════════════════════
   Tab switch
══════════════════════════════════════════ */
function switchTab(tab) {
    currentTab = tab;
    document.getElementById('pv-idle').style.display  = tab === 'idle'  ? 'flex' : 'none';
    document.getElementById('pv-guest').style.display = tab === 'guest' ? 'flex' : 'none';
    document.getElementById('tab-idle').classList.toggle('active',  tab === 'idle');
    document.getElementById('tab-guest').classList.toggle('active', tab === 'guest');
}

/* ══════════════════════════════════════════
   Scale preview to fit stage
══════════════════════════════════════════ */
function scalePreview() {
    const stage  = document.getElementById('preview-stage');
    const wrap   = document.getElementById('pv-shadow-wrap');
    const pw = 1280, ph = 720, pad = 40;
    const sx = (stage.clientWidth  - pad) / pw;
    const sy = (stage.clientHeight - pad) / ph;
    const s  = Math.min(sx, sy);
    const ox = (stage.clientWidth  - pw * s) / 2;
    const oy = (stage.clientHeight - ph * s) / 2;
    wrap.style.width     = pw + 'px';
    wrap.style.height    = ph + 'px';
    wrap.style.transform = `scale(${s})`;
    wrap.style.left      = ox + 'px';
    wrap.style.top       = oy + 'px';
}
window.addEventListener('resize', scalePreview);

/* ══════════════════════════════════════════
   Color picker ↔ hex input sync
══════════════════════════════════════════ */
const colorFields = [
    'backgroundColor', 'welcomeTextColor', 'guestNameColor',
    'guestNameAccentColor', 'cornerBorderColor', 'avatarRingColor'
];

function initColorSync() {
    colorFields.forEach(key => {
        const picker = document.getElementById(`c-${key}-picker`);
        const hex    = document.getElementById(`c-${key}`);
        if (!picker || !hex) return;

        picker.addEventListener('input', () => {
            hex.value = picker.value;
            cfg[key]  = picker.value;
            updatePreview();
        });
        hex.addEventListener('input', () => {
            const v = hex.value.trim();
            if (/^#[0-9a-fA-F]{6}$/.test(v)) {
                picker.value = v;
                cfg[key]     = v;
                updatePreview();
            }
        });
    });
}

/* ══════════════════════════════════════════
   Slider value display
══════════════════════════════════════════ */
const sliderFields = [
    { id: 'welcomeTextSizePx',      unit: 'px' },
    { id: 'guestNameSizePx',        unit: 'px' },
    { id: 'idleTitleSizePx',        unit: 'px' },
    { id: 'displayDurationSeconds', unit: 's'  },
    { id: 'pollIntervalSeconds',     unit: 's'  },
    // Positions
    { id: 'guestContentOffsetY', unit: 'px' },
    { id: 'welcomeTextOffsetX',  unit: 'px' },
    { id: 'welcomeTextOffsetY',  unit: 'px' },
    { id: 'avatarOffsetX',       unit: 'px' },
    { id: 'avatarOffsetY',       unit: 'px' },
    { id: 'guestNameOffsetX',    unit: 'px' },
    { id: 'guestNameOffsetY',    unit: 'px' },
    { id: 'idleContentOffsetY',  unit: 'px' },
];

function initSliders() {
    sliderFields.forEach(({ id, unit }) => {
        const el  = document.getElementById(`c-${id}`);
        const val = document.getElementById(`c-${id}-val`);
        if (!el || !val) return;
        el.addEventListener('input', () => {
            val.textContent = el.value + unit;
            cfg[id] = Number(el.value);
            updatePreview();
        });
    });
}

/* ══════════════════════════════════════════
   Text inputs
══════════════════════════════════════════ */
const textFields = ['welcomeText', 'idleTitle', 'idleSubtitle', 'brandName', 'brandSubtitle'];

function initTextInputs() {
    textFields.forEach(key => {
        const el = document.getElementById(`c-${key}`);
        if (!el) return;
        el.addEventListener('input', () => {
            cfg[key] = el.value;
            updatePreview();
        });
    });
}

/* ══════════════════════════════════════════
   Radio buttons
══════════════════════════════════════════ */
function initRadios() {
    document.querySelectorAll('input[name="fwIntensity"]').forEach(r => {
        r.addEventListener('change', () => {
            cfg.fireworksIntensity = r.value;
            highlightRadio(r.value);
        });
    });
}

function highlightRadio(val) {
    ['low','medium','high'].forEach(v => {
        document.getElementById(`rb-${v}`).classList.toggle('selected', v === val);
    });
}

/* ══════════════════════════════════════════
   Toggle
══════════════════════════════════════════ */
function initToggle() {
    const el = document.getElementById('c-showFireworks');
    el.addEventListener('change', () => {
        cfg.showFireworks = el.checked;
    });
}

/* ══════════════════════════════════════════
   Populate form from cfg
══════════════════════════════════════════ */
function populateForm() {
    // Text
    textFields.forEach(k => {
        const el = document.getElementById(`c-${k}`);
        if (el) el.value = cfg[k] ?? '';
    });
    // Colors
    colorFields.forEach(k => {
        const picker = document.getElementById(`c-${k}-picker`);
        const hex    = document.getElementById(`c-${k}`);
        const v      = cfg[k] ?? '#C8102E';
        if (picker) picker.value = v;
        if (hex)    hex.value    = v;
    });
    // Sliders
    sliderFields.forEach(({ id, unit }) => {
        const el  = document.getElementById(`c-${id}`);
        const val = document.getElementById(`c-${id}-val`);
        if (el)  el.value       = cfg[id] ?? el.min;
        if (val) val.textContent = (cfg[id] ?? el?.min ?? '') + unit;
    });
    // Toggle
    const fw = document.getElementById('c-showFireworks');
    if (fw) fw.checked = cfg.showFireworks !== false;
    // Radio
    highlightRadio(cfg.fireworksIntensity || 'medium');
    const r = document.querySelector(`input[name="fwIntensity"][value="${cfg.fireworksIntensity || 'medium'}"]`);
    if (r) r.checked = true;
}

/* ══════════════════════════════════════════
   Live preview update
══════════════════════════════════════════ */
function css(el, styles) {
    if (!el) return;
    Object.assign(el.style, styles);
}

function updatePreview() {
    const c = cfg;
    const bg = c.backgroundColor || '#fff';
    const accent = c.cornerBorderColor || '#C8102E';

    // Background
    document.getElementById('pv-canvas').style.background = bg;

    // Corners
    document.querySelectorAll('.pv-corner.tl, .pv-corner.tr').forEach(el => {
        el.style.borderTopColor  = accent;
        el.style.borderLeftColor = el.classList.contains('tl') ? accent : '';
        el.style.borderRightColor = el.classList.contains('tr') ? accent : '';
    });
    document.querySelectorAll('.pv-corner.bl, .pv-corner.br').forEach(el => {
        el.style.borderBottomColor = accent;
        el.style.borderLeftColor   = el.classList.contains('bl') ? accent : '';
        el.style.borderRightColor  = el.classList.contains('br') ? accent : '';
    });

    // Idle
    css(document.getElementById('pv-divider'),    { background: `linear-gradient(90deg,transparent,${accent},transparent)` });
    css(document.getElementById('pv-idle-title'), { fontSize: (c.idleTitleSizePx || 22)+'px', color: c.guestNameColor || '#1a1a1a' });
    css(document.getElementById('pv-idle-sub'),   { color: c.welcomeTextColor || '#C8102E' });

    const idleTitle = document.getElementById('pv-idle-title');
    const idleSub   = document.getElementById('pv-idle-sub');
    if (idleTitle) idleTitle.textContent = c.idleTitle || 'Hệ thống chào mừng';
    if (idleSub)   idleSub.textContent   = c.idleSubtitle || 'VIP Welcome System';

    // Guest header
    const pvBrandName = document.getElementById('pv-brand-name');
    const pvBrandSub  = document.getElementById('pv-brand-sub');
    const pvGSep      = document.getElementById('pv-g-sep');
    if (pvBrandName) pvBrandName.textContent = c.brandName || 'Sigma';
    if (pvBrandSub)  { pvBrandSub.textContent = c.brandSubtitle || 'VIP Welcome'; pvBrandSub.style.color = accent; }
    if (pvGSep)      pvGSep.style.background = accent;

    // Welcome text
    const pvWelcome = document.getElementById('pv-welcome');
    if (pvWelcome) {
        pvWelcome.textContent = c.welcomeText || '✦  Kính chào Quý Khách  ✦';
        pvWelcome.style.color    = c.welcomeTextColor || '#C8102E';
        pvWelcome.style.fontSize = (c.welcomeTextSizePx || 28) + 'px';
    }

    // Avatar ring
    const ringColor = c.avatarRingColor || '#C8102E';
    css(document.getElementById('pv-ring-pulse'), { borderColor: `rgba(${hexToRgb(ringColor)},0.3)` });
    css(document.getElementById('pv-ring-spin'),  { borderTopColor: ringColor, borderRightColor: `rgba(${hexToRgb(ringColor)},0.25)` });
    css(document.getElementById('pv-avatar'),     { boxShadow: `0 0 0 2px ${ringColor}`, color: ringColor });

    // Ornament
    const ornColor = accent;
    css(document.getElementById('pv-orn-l'),   { background: `linear-gradient(90deg,transparent,${ornColor})` });
    css(document.getElementById('pv-orn-r'),   { background: `linear-gradient(90deg,${ornColor},transparent)` });
    css(document.getElementById('pv-orn-dot'), { background: ornColor });

    // Guest name
    const pvName       = document.getElementById('pv-name');
    const pvNameAccent = document.getElementById('pv-name-accent');
    if (pvName)       pvName.style.fontSize   = (c.guestNameSizePx || 52) + 'px';
    if (pvName)       pvName.style.color      = c.guestNameColor || '#1a1a1a';
    if (pvNameAccent) pvNameAccent.style.color = c.guestNameAccentColor || '#C8102E';

    // ── Positions ──
    // Guest content block
    const pvGuestScreen = document.getElementById('pv-guest');
    if (pvGuestScreen) {
        pvGuestScreen.style.transform = `translateY(${c.guestContentOffsetY || 0}px)`;
        pvGuestScreen.style.alignItems = 'center';
    }
    // Welcome text
    if (pvWelcome) pvWelcome.style.transform = `translate(${c.welcomeTextOffsetX||0}px, ${c.welcomeTextOffsetY||0}px)`;
    // Avatar
    const pvAvatar = document.querySelector('#pv-guest .pv-avatar-wrap');
    if (pvAvatar) pvAvatar.style.transform = `translate(${c.avatarOffsetX||0}px, ${c.avatarOffsetY||0}px)`;
    // Guest name
    if (pvName) pvName.style.transform = `translate(${c.guestNameOffsetX||0}px, ${c.guestNameOffsetY||0}px)`;
    // Idle content block
    const pvIdleScreen = document.getElementById('pv-idle');
    if (pvIdleScreen) pvIdleScreen.style.transform = `translateY(${c.idleContentOffsetY||0}px)`;
}

function hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return isNaN(r) ? '200,16,46' : `${r},${g},${b}`;
}

/* ══════════════════════════════════════════
   Save config
══════════════════════════════════════════ */
async function saveConfig() {
    const btn = document.getElementById('btn-save');
    btn.textContent = 'Đang lưu...';
    btn.classList.add('saving');
    try {
        const res = await fetch('/Admin/SaveConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cfg),
        });
        let data;
        try { data = await res.json(); } catch { data = { success: false, message: `HTTP ${res.status}` }; }
        if (data.success) {
            showToast('✓  Lưu thành công — giao diện đã được cập nhật', false);
        } else {
            showToast(`✕  Lưu thất bại: ${data.message || res.status}`, true);
        }
    } catch (e) {
        showToast(`✕  Lỗi kết nối: ${e.message}`, true);
    } finally {
        btn.textContent = 'Lưu & Áp dụng';
        btn.classList.remove('saving');
    }
}

/* ══════════════════════════════════════════
   Toast
══════════════════════════════════════════ */
let toastTimer;
function showToast(msg, isError) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.className = 'toast show' + (isError ? ' error' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

/* ══════════════════════════════════════════
   Reset positions
══════════════════════════════════════════ */
function resetPositions() {
    const posKeys = ['guestContentOffsetY','welcomeTextOffsetX','welcomeTextOffsetY',
                     'avatarOffsetX','avatarOffsetY','guestNameOffsetX','guestNameOffsetY','idleContentOffsetY'];
    posKeys.forEach(k => {
        cfg[k] = 0;
        const el  = document.getElementById(`c-${k}`);
        const val = document.getElementById(`c-${k}-val`);
        if (el)  el.value       = 0;
        if (val) val.textContent = '0px';
    });
    updatePreview();
}

/* ══════════════════════════════════════════
   Load config & init
══════════════════════════════════════════ */
async function init() {
    try {
        const res = await fetch('/Admin/Config');
        cfg = await res.json();
    } catch {
        cfg = {};
    }
    populateForm();
    initColorSync();
    initSliders();
    initTextInputs();
    initRadios();
    initToggle();
    updatePreview();
    scalePreview();
}

init();

/* ══════════════════════════════════════════
   VIP Photo Upload
══════════════════════════════════════════ */
async function loadVipEmployees() {
    const sel = document.getElementById('vip-emp-select');
    try {
        const res = await fetch('/Admin/GetVipEmployees');
        const list = await res.json();
        sel.innerHTML = '<option value="">-- Chọn khách VIP --</option>';
        list.forEach(e => {
            const opt = document.createElement('option');
            opt.value = e.empCode;
            opt.textContent = e.displayName;
            sel.appendChild(opt);
        });
    } catch {
        sel.innerHTML = '<option value="">-- Không tải được danh sách --</option>';
    }
}

document.getElementById('vip-photo-input').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const preview = document.getElementById('vip-photo-preview');
    const zone    = document.getElementById('upload-zone');
    const reader  = new FileReader();
    reader.onload = ev => {
        preview.src          = ev.target.result;
        preview.style.display = 'block';
        zone.style.display   = 'none';
    };
    reader.readAsDataURL(file);
});

async function uploadVipPhoto() {
    const empCode   = document.getElementById('vip-emp-select').value;
    const fileInput = document.getElementById('vip-photo-input');
    const btn       = document.getElementById('btn-upload');

    if (!empCode)            { showToast('✕  Vui lòng chọn khách VIP', true); return; }
    if (!fileInput.files[0]) { showToast('✕  Vui lòng chọn ảnh', true);      return; }

    btn.textContent = 'Đang upload...';
    btn.disabled    = true;

    const fd = new FormData();
    fd.append('empCode', empCode);
    fd.append('photo',   fileInput.files[0]);

    try {
        const res  = await fetch('/Admin/UploadVipPhoto', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            showToast(`✓  ${data.message}`, false);
            fileInput.value = '';
            document.getElementById('vip-photo-preview').style.display = 'none';
            document.getElementById('upload-zone').style.display       = 'flex';
        } else {
            showToast(`✕  ${data.message}`, true);
        }
    } catch (e) {
        showToast(`✕  Lỗi: ${e.message}`, true);
    } finally {
        btn.textContent = '⬆ Upload ảnh';
        btn.disabled    = false;
    }
}

loadVipEmployees();
</script>
</body>
</html>
