                        <div class="pv-idle-title" id="pv-idle-title">Hệ thống chào mừng</div>
                        <div class="pv-idle-sub"   id="pv-idle-sub">VIP Welcome System</div>
                    </div>

                    <!-- GUEST SCREEN -->
                    <div class="pv-screen" id="pv-guest" style="display:none">
                        <div class="pv-corner tl"></div>
                        <div class="pv-corner tr"></div>
                        <div class="pv-corner bl"></div>
                        <div class="pv-corner br"></div>

                        <div class="pv-g-header">
                            <img src="/images/logo.jpg" class="pv-g-logo" alt="Logo" />
                            <div class="pv-g-sep" id="pv-g-sep"></div>
                            <div>
                                <div class="pv-brand-name" id="pv-brand-name">Sigma</div>
                                <div class="pv-brand-sub"  id="pv-brand-sub">VIP Welcome</div>
                            </div>
                        </div>

                        <div class="pv-welcome" id="pv-welcome">✦  Kính chào Quý Khách  ✦</div>

