                        </div>
                    </div>
                    <div class="field-sep"></div>
                    <div class="pos-group-label">Tên khách</div>
                    <div class="field">
                        <label>Ngang (X)</label>
                        <div class="slider-row">
                            <input type="range" id="c-guestNameOffsetX" min="-500" max="500" step="5" />
                            <span class="slider-val" id="c-guestNameOffsetX-val"></span>
                        </div>
                    </div>
                    <div class="field">
                        <label>Dọc (Y)</label>
                        <div class="slider-row">
                            <input type="range" id="c-guestNameOffsetY" min="-300" max="300" step="5" />
                            <span class="slider-val" id="c-guestNameOffsetY-val"></span>
